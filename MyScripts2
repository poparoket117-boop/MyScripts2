-- Копируем кнопки в перетаскиваемое окно
local function CopyButtons(from, to)
    for _, child in pairs(from:GetChildren()) do
        if child:IsA("TextButton") and child ~= from:FindFirstChild("Close") then
            local newBtn = child:Clone()
            newBtn.Parent = to
            newBtn.MouseButton1Click:Connect(function()
                -- Перенаправляем на оригинальные функции
                if newBtn.Text:find("NoClip") then
                    noclip = not noclip
                    SetNoClip(noclip)
                    newBtn.Text = noclip and "NoClip: ON" or "NoClip: OFF"
                    newBtn.TextColor3 = noclip and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(0, 0, 0)
                    ncBtn.Text = newBtn.Text
                    ncBtn.TextColor3 = newBtn.TextColor3
                elseif newBtn.Text:find("InfJump") then
                    infJump = not infJump
                    SetInfJump(infJump)
                    if infJump then startInfJump() end
                    newBtn.Text = infJump and "InfJump: ON" or "InfJump: OFF"
                    newBtn.TextColor3 = infJump and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(0, 0, 0)
                    ijBtn.Text = newBtn.Text
                    ijBtn.TextColor3 = newBtn.TextColor3
                elseif newBtn.Text:find("God Mode") then
                    god = not god
                    SetGod(god)
                    newBtn.Text = god and "God Mode: ON" or "God Mode: OFF"
                    newBtn.TextColor3 = god and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(0, 0, 0)
                    godBtn.Text = newBtn.Text
                    godBtn.TextColor3 = newBtn.TextColor3
                elseif newBtn.Text:find("Fun Mode") then
                    funMode = not funMode
                    newBtn.Text = funMode and "Fun Mode: ON" or "Fun Mode: OFF"
                    newBtn.TextColor3 = funMode and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(0, 0, 0)
                    funBtn.Text = newBtn.Text
                    funBtn.TextColor3 = newBtn.TextColor3
                elseif newBtn.Text:find("Mode") then
                    local modes = {"Circle", "Follow", "Spin"}
                    local current = 1
                    for i, v in ipairs(modes) do
                        if v == funModeType then current = i break end
                    end
                    current = current % 3 + 1
                    funModeType = modes[current]
                    newBtn.Text = "Mode: " .. funModeType
                    modeBtn.Text = newBtn.Text
                elseif newBtn.Text:find("Enable All") then
                    noclip = true
                    infJump = true
                    god = true
                    funMode = true
                    SetNoClip(true)
                    SetInfJump(true)
                    startInfJump()
                    SetGod(true)
                    ncBtn.Text = "NoClip: ON"
                    ncBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
                    ijBtn.Text = "InfJump: ON"
                    ijBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
                    godBtn.Text = "God Mode: ON"
                    godBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
                    funBtn.Text = "Fun Mode: ON"
                    funBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
                    for _, b in pairs(dragFuncFrame:GetChildren()) do
                        if b:IsA("TextButton") and b.Text:find("NoClip") then
                            b.Text = "NoClip: ON"
                            b.TextColor3 = Color3.fromRGB(0, 255, 0)
                        elseif b:IsA("TextButton") and b.Text:find("InfJump") then
                            b.Text = "InfJump: ON"
                            b.TextColor3 = Color3.fromRGB(0, 255, 0)
                        elseif b:IsA("TextButton") and b.Text:find("God Mode") then
                            b.Text = "God Mode: ON"
                            b.TextColor3 = Color3.fromRGB(0, 255, 0)
                        elseif b:IsA("TextButton") and b.Text:find("Fun Mode") then
                            b.Text = "Fun Mode: ON"
                            b.TextColor3 = Color3.fromRGB(0, 255, 0)
                        end
                    end
                end
            end)
        elseif child:IsA("TextLabel") and not child.Text:find("Drag") then
            local newLabel = child:Clone()
