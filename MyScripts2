-- ============================================
-- FLY (полёт)
-- ============================================
local bodyVelocity = nil
local bodyGyro = nil

local function StartFly()
    if not fly or not root then return end
    if not bodyVelocity then
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = root
    end
    if not bodyGyro then
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyGyro.P = 1e5
        bodyGyro.CFrame = root.CFrame
        bodyGyro.Parent = root
    end
    
    local cam = workspace.CurrentCamera
    local moveDir = Vector3.new(0, 0, 0)
    local uis = game:GetService("UserInputService")
    
    if uis:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
    if uis:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
    
    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit * flySpeed
    end
    bodyVelocity.Velocity = moveDir
    bodyGyro.CFrame = cam.CFrame
end

game:GetService("RunService").Heartbeat:Connect(StartFly)

-- ============================================
-- АУРА
-- ============================================
local function CreateAura()
    for _, copy in pairs(auraCopies) do
        if copy and copy.Parent then copy:Destroy() end
    end
    auraCopies = {}
    if not auraMode then return end
    
    local players = {}
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then table.insert(players, p) end
    end
    if #players == 0 then
        for i = 1, 8 do table.insert(players, player) end
    end
    
    local count = math.min(#players, 10)
    for i = 1, count do
        local p = players[i]
        local copy = p.Character and p.Character:Clone() or char:Clone()
        if copy then
            copy.Parent = workspace
            copy.Name = "AuraCopy_" .. i
            for _, v in pairs(copy:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.Transparency = 0.5
                    v.Material = Enum.Material.Neon
                    v.CanCollide = false
                end
            end
            local h = copy:FindFirstChild("Humanoid")
            if h then h:Destroy() end
            table.insert(auraCopies, copy)
        end
    end
end

game:GetService("RunService").Heartbeat:Connect(function()
    if not auraMode or not root then
        for _, copy in pairs(auraCopies) do
            if copy and copy.Parent then copy:Destroy() end
        end
        auraCopies = {}
        return
    end
    
    local now = tick()
    for i, copy in pairs(auraCopies) do
        if copy and copy.Parent then
            local angle = (now * auraSpeed) + (i / #auraCopies) * 2 * math.pi
            local x = math.cos(angle) * auraRadius
            local z = math.sin(angle) * auraRadius
            local y = math.sin(angle * 0.7) * 2
            local pos = root.Position + Vector3.new(x, y, z)
            copy:SetPrimaryPartCFrame(CFrame.new(pos, root.Position))
        end
    end
end)

-- ============================================
-- ФАН-РЕЖИМ
-- ============================================
game:GetService("RunService").Heartbeat:Connect(function()
    if not funMode or not root then return end
    
    if funModeType == "Spin" then
        root.CFrame = root.CFrame * CFrame.Angles(0, 0.1 * (funSpeed / 10), 0)
        return
    end
    
    local target = nil
    if targetPlayer then
        local plr = game:GetService("Players"):FindFirstChild(targetPlayer)
        if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            target = plr.Character.HumanoidRootPart
        else
            targetPlayer = nil
        end
    end
    
    if not target then
        local closest = nil
        local closestDist = 50
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (root.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = p.Character.HumanoidRootPart
                end
            end
        end
        target = closest
    end
    
    if not target then return end
    
    if funModeType == "Circle" then
        local speedFactor = funSpeed / 10
        circleAngle = circleAngle + 0.05 * speedFactor
        local radius = 2
        local offset = Vector3.new(math.cos(circleAngle) * radius, 0, math.sin(circleAngle) * radius)
        local targetPos = target.Position + offset
        root.CFrame = CFrame.new(targetPos, target.Position)
    elseif funModeType == "Follow" then
        local speedFactor = funSpeed / 10
        local direction = (target.Position - root.Position).Unit
        root.CFrame = root.CFrame + direction * (0.5 * speedFactor)
    end
end)

