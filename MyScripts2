local function SaveConfig()
    config.noclip = noclip
    config.infJump = infJump
    config.god = god
    config.walkSpeed = walkSpeed
    config.flySpeed = flySpeed
    config.funSpeed = funSpeed
    config.auraSpeed = auraSpeed
    config.funModeType = funModeType
    writefile("DrunixHub_Config.txt", game:GetService("HttpService"):JSONEncode(config))
    print("[DrunixHub] Config saved!")
end

local function LoadConfig()
    if isfile("DrunixHub_Config.txt") then
        local data = game:GetService("HttpService"):JSONDecode(readfile("DrunixHub_Config.txt"))
        if data then
            noclip = data.noclip or false
            infJump = data.infJump or false
            god = data.god or false
            walkSpeed = data.walkSpeed or 16
            flySpeed = data.flySpeed or 50
            funSpeed = data.funSpeed or 20
            auraSpeed = data.auraSpeed or 1.5
            funModeType = data.funModeType or "Circle"
            print("[DrunixHub] Config loaded!")
        end
    end
end

