local function RefreshDragPlayerList()
    for _, child in pairs(dragPlayerScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    local list = {}
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then
            table.insert(list, p.Name)
        end
    end
    if #list == 0 then
        table.insert(list, "No players")
    end
    dragPlayerScroll.CanvasSize = UDim2.new(0, 0, 0, #list * 32 + 10)
    for _, item in ipairs(list) do
        local btn = Instance.new("TextButton", dragPlayerScroll)
        btn.Size = UDim2.new(0.9, 0, 0, 28)
        btn.Text = item
        btn.TextColor3 = Color3.fromRGB(0, 0, 0)
        btn.TextSize = 13
        btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        btn.BackgroundTransparency = 0.1
        btn.BorderSizePixel = 1
        btn.BorderColor3 = Color3.fromRGB(0, 0, 0)
        local bCorner = Instance.new("UICorner", btn)
        bCorner.CornerRadius = UDim.new(0, 8)
        btn.MouseButton1Click:Connect(function()
            if item == "No players" then return end
            targetPlayer = item
            for _, child in pairs(dragPlayerScroll:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    child.BackgroundTransparency = 0.1
                end
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            btn.BackgroundTransparency = 0.3
            -- Обновляем и в статическом окне
            for _, child in pairs(playerScroll:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    child.BackgroundTransparency = 0.1
                end
            end
            for _, child in pairs(playerScroll:GetChildren()) do
                if child:IsA("TextButton") and child.Text == item then
                    child.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                    child.BackgroundTransparency = 0.3
                end
            end
            print("Target set to: " .. item)
        end)
    end
end

